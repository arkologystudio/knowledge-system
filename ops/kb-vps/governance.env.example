# KS-E — governance token introspection for `gbrain serve --http`.
#
# Install as /etc/gbrain/governance.env (chmod 600, root-owned) and load it from
# knowledge-system-http.service. Introspection is OFF unless
# GBRAIN_GOVERNANCE_INTROSPECT_URL is set, and FAILS CLOSED (governance-prefixed
# tokens DENIED) if the URL is set but the client id/secret are missing — the
# server warns loudly at startup either way. NEVER commit real values.

# The habitat-governance RFC 7662 introspection endpoint.
GBRAIN_GOVERNANCE_INTROSPECT_URL=https://gov.arkology.studio/v1/introspect

# The `ks-engine` confidential client (scope: introspect) registered by
# habitat-governance/scripts/register-governance-clients.sh. Client-credentials
# are read from env ONLY — never hardcoded, never logged.
GBRAIN_GOVERNANCE_CLIENT_ID=
GBRAIN_GOVERNANCE_CLIENT_SECRET=

# Cache TTL for introspection results (ms). Default 0 = no caching = instant
# revocation. Raise only if introspection latency becomes a problem; the
# provider hard-caps it regardless.
GBRAIN_GOVERNANCE_CACHE_TTL_MS=0

# Optional: per-call introspection timeout (ms). Sensible default applied when unset.
# GBRAIN_GOVERNANCE_INTROSPECT_TIMEOUT_MS=2000

# Optional: comma-list of token prefixes routed to governance introspection.
# Defaults cover the governance mint (hab_at_ / hab_pat_) — leave unset unless
# the mint prefix changes.
# GBRAIN_GOVERNANCE_TOKEN_PREFIXES=hab_at_,hab_pat_
